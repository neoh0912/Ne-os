#!/usr/bin/env bash

ROOT=$PWD/.build/initramfs
DIR=$PWD

GLIBC=$PWD/.build/glibc

rm -frd $ROOT

mkdir -p $ROOT

cp -a $PWD/initramfs/. $ROOT/

mkdir -p $ROOT/{bin,boot,dev,etc,lib,mnt,opt,proc,root,run,sbin,sys,usr,var}
mkdir -p $ROOT/usr/{bin,include,lib,libexec,local,sbin,share,src}

cp $GLIBC/lib/{libc.so.6,libm.so.6,libdl.so.2,libpthread.so.0} $ROOT/lib
cp $GLIBC/lib64/ld-linux-x86-64.so.2 $ROOT/lib
